rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // All user data is private — only the authenticated user can access it.
    // NOTE: Parent match /users/{uid} does NOT cover subcollections — each
    // subcollection carries its own rules to avoid accidental permission bleed.
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/profile/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/settings/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/presets/{presetId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/timerState/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/sessions/{sessionId} {
      allow read: if isOwner(uid);
      // Sessions are immutable once created — no updates or deletes allowed
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    match /users/{uid}/tags/{tagId} {
      allow read, write: if isOwner(uid);
    }
  }
}
